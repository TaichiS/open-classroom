# ============================================================
# Supabase 設定
# 到 https://supabase.com 建立專案後，從以下位置取得：
# Project Settings → API → Project URL & anon public key
# ============================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# API Routes (Vercel Serverless Functions) — same value as VITE_SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (用於 API routes，保密勿外洩)
# 從 Supabase → Project Settings → API → service_role secret 取得
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
